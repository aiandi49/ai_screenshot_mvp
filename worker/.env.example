# Copy this file's structure into Render's Environment Variables UI.
# Never commit a real .env file — this is a template only.

# Supabase → Project Settings → API
SUPABASE_URL=https://hgbiuqkjozruytgsdinc.supabase.co

# Supabase → Project Settings → API → service_role (secret)
# This key bypasses RLS — it must ONLY exist here (in Render's env vars),
# never in the frontend, never committed to git.
SUPABASE_SERVICE_ROLE_KEY=

# Render sets this automatically — only needed for local testing
PORT=3000
